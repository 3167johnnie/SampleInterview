<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
 "-//Apache Software Foundation//DTD Struts Configuration 2.0//EN"
 "http://struts.apache.org/dtds/struts-2.0.dtd">

<!-- Home Loan action -->

<struts>

	<package name="cve-loan-actions" extends="sbi">
                <action name="initpersonalloan" method="initPersonalLoan" class="cveLoanAction">
                        <result name="success" type="json">
                                <param name="root">json</param>
                        </result>
                </action>

		<action name="cve" method="cveLoan" class="cveLoanAction">
			<interceptor-ref name="defaultStack"></interceptor-ref>
			<interceptor-ref name="defaultFileUploadStack"></interceptor-ref>
			<result name="jsonResponsePage">/app/common/jsonResponsePage.jsp</result>
			<result name="downLoadPDF" type="stream">
			  <param name="contentType">application/pdf</param>
			  	<param name="allowCaching">false</param>
				<param name="inputName">inputStream</param>
				<param name="contentDisposition">filename=Personal-Loan.pdf</param> 
				<param name="bufferSize">1024</param> 
			</result>
			<result name="homePage">/appNew/loan/personal/PersonalLoan.jsp</result>
			<result name="firstPage">/appNew/loan/personal/PersonalFirstPage.jsp</result>
			<result name="secondPage">/appNew/loan/personal/PersonalFirstPage.jsp</result>
			<result name="secondPageChange">/appNew/loan/personal/PersonalFirstPage.jsp</result>
			<result name="consentRevoke">/appNew/common/CommonCbsCveNonConsentRevoke.jsp</result>
			<result name="thirdPage">/appNew/loan/personal/PersonalFirstPage.jsp</result>
			<result name="thankYouPage">/appNew/common/LoanThankYou.jsp</result>
			<result name="thankYouPageCve">/appNew/common/PersonalFirstPage.jsp</result>
			<result name="repaymentScheduled">/appNew/common/RepaymentScheduled.jsp</result>
			<result name="secondPageWithHeader">/appNew/loan/personal/PersonalSecondPageWithHeader.jsp</result>
			<result name="cbsOtpPage">/appNew/common/CommonCbsOtp.jsp</result>
			<result name="otpPageElite">/appNew/loan/personal/includes/OtpPageElite.jsp</result>
	    </action>

	</package>

</struts>	
