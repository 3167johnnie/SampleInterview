<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
 "-//Apache Software Foundation//DTD Struts Configuration 2.0//EN"
 "http://struts.apache.org/dtds/struts-2.0.dtd">
 
 <!-- CreditCard Action Actions -->
 
 <struts>
 	<package name="credit-card-actions" extends="sbi">
 		<action name="initCreditCard" method="initCreditCard" class="creditCardAction">
			<result name="success" type="json">
				<param name="root">json</param>
			</result>
		</action>
		
		<action name="credit-card" method="creditCard" class="creditCardAction">
			<!-- <interceptor-ref name="token"></interceptor-ref> -->
			<interceptor-ref name="defaultStack"></interceptor-ref>
			<interceptor-ref name="defaultFileUploadStack"></interceptor-ref>
			<result name="homePageOld">/app/loan/creditcard/creditCard.jsp</result>
			<result name="firstPageOld">/app/loan/creditcard/creditCardFirstPage.jsp</result>
			<result name="secondPageOld">/app/loan/creditcard/creditCardSecondPage.jsp</result> 
			<result name="thankYouPageOld">/app/common/loanThankYou.jsp</result>
			<result name="jsonResponsePage">/app/common/jsonResponsePage.jsp</result>
			<!-- <result name="secondPageWithHeaderOld">/app/loan/creditcard/creditCardSecondPageWithHeader.jsp</result> -->
			<result name="downLoadPDF" type="stream">
			  <param name="contentType">application/pdf</param>
				<param name="inputName">inputStream</param>
				<param name="contentDisposition">filename=Credit-card.pdf</param> 
				<param name="bufferSize">1024</param> 
			</result>
			<result name="cbsOtpPageOld">/app/common/commonCbsOtp.jsp</result>
			
			<result name="homePage">/appNew/loan/creditcard/CreditCard.jsp</result>
			<result name="firstPage">/appNew/loan/creditcard/CreditCardFirstPage.jsp</result>
			<result name="secondPage">/appNew/loan/creditcard/CreditCardFirstPage.jsp</result>
			<result name="thankYouPage">/appNew/loan/creditcard/CreditCardFirstPage.jsp</result>
			<result name="cbsOtpPage">/appNew/common/CommonCbsOtp.jsp</result>
		</action>
		
		<action name="credit-card-dsr" method="creditCardDSR" class="creditCardAction">
			<interceptor-ref name="defaultStack"></interceptor-ref>
			<interceptor-ref name="defaultFileUploadStack"></interceptor-ref>
			<result name="homePageOld">/app/dsr/creditcard/dsrCreditCard.jsp</result>
			<result name="firstPageOld">/app/dsr/creditcard/dsrFirstPage.jsp</result>
			<result name="thankYouPageOld">/app/common/dsrThankYou.jsp</result>
			<result name="jsonResponsePage">/app/common/jsonResponsePage.jsp</result>
			<result name="callsLogDetailsOld">/app/common/callLogDetails.jsp</result>
			<!-- <result name="biometricCaptureOld">/app/common/biometricCapture.jsp</result> -->
			<result name="downLoadPDF" type="stream">
			  <param name="contentType">application/pdf</param>
				<param name="inputName">inputStream</param>
				<param name="contentDisposition">filename=Credit-card.pdf</param> 
				<param name="bufferSize">1024</param> 
			</result>
			<result name="cbsVerifySmsOtpPageOld">/app/common/commonCbsVarifySmsOtp.jsp</result>
		</action>
		
		<action name="getCardEmployerName" method="getCardEmployerName" class="creditCardAction">
			<result name="success" type="json">
				<param name="root">json</param>
			</result>
		</action>
		
		
		
	</package>
</struts>	
