 <!-- Agri Loan Action Actions -->
 
 <struts>
 	<package name="agri-loan-actions" extends="sbi">
 		<action name="initagriloan" method="initAgriLoan" class="agriLoanAction">
			<result name="success" type="json">
				<param name="root">json</param>
			</result>
		</action>
		
		<action name="agri-loan" method="agriLoan" class="agriLoanAction">
			<!-- <interceptor-ref name="token"></interceptor-ref> -->
			<interceptor-ref name="defaultStack"></interceptor-ref>
			<interceptor-ref name="defaultFileUploadStack"></interceptor-ref>
			<result name="homePageOld">/app/loan/agriloan/agriLoan.jsp</result>
			<result name="firstPageOld">/app/loan/agriloan/agriFirstPage.jsp</result>
			<result name="secondPageOld">/app/loan/agriloan/agriSecondPage.jsp</result>
			<result name="thankYouPageOld">/app/loan/agriloan/agriThankYou.jsp</result>
			<result name="jsonResponsePage">/app/common/jsonResponsePage.jsp</result>
			<result name="downLoadPDF" type="stream">
			  <param name="contentType">application/pdf</param>
				<param name="inputName">inputStream</param>
				<param name="contentDisposition">filename=Agri-Loan.pdf</param> 
				<param name="bufferSize">1024</param> 
			</result>
			<result name="cbsOtpPageOld">/app/common/commonCbsOtp.jsp</result>
			
			<result name="homePage">/appNew/loan/agriloan/AgriLoan.jsp</result>
			<result name="firstPage">/appNew/loan/agriloan/AgriFirstPage.jsp</result>
			<result name="secondPage">/appNew/loan/agriloan/AgriFirstPage.jsp</result>
			<result name="thankYouPage">/appNew/loan/agriloan/AgriFirstPage.jsp</result>
			<result name="cbsOtpPage">/appNew/common/CommonCbsOtp.jsp</result>
		</action>
		
		<action name="agri-loan-dsr" method="agriLoanDSR" class="agriLoanAction">
			<interceptor-ref name="defaultStack"></interceptor-ref>
			<interceptor-ref name="defaultFileUploadStack"></interceptor-ref>
			<result name="homePageOld">/app/dsr/agriloan/dsrAgriLoan.jsp</result>
			<result name="firstPageOld">/app/dsr/agriloan/dsrFirstPage.jsp</result>
			<result name="thankYouPageOld">/app/common/dsrThankYou.jsp</result>
			<result name="jsonResponsePage">/app/common/jsonResponsePage.jsp</result>
			<result name="callsLogDetailsOld">/app/common/callLogDetails.jsp</result>
			<!-- <result name="biometricCaptureOld">/app/common/biometricCapture.jsp</result> -->
			<result name="downLoadPDF" type="stream">
			  <param name="contentType">application/pdf</param>
				<param name="inputName">inputStream</param>
				<param name="contentDisposition">filename=Agri-Loan.pdf</param> 
				<param name="bufferSize">1024</param> 
			</result>
			<result name="cbsVerifySmsOtpPageOld">/app/common/commonCbsVarifySmsOtp.jsp</result>
		</action>

		<action name="agriMake" method="agriMake" class="agriLoanAction">
			<result name="success" type="json">
       	 		<param name="root">json</param>
       		</result>
      	</action>
      	
      	<action name="agriModel" method="getAgriModelByMakeId" class="agriLoanAction">
			<result name="success" type="json">
       	 		<param name="root">json</param>
       		</result>
      	</action>
      	<action name="getAgriState" method="getAgriState" class="agriLoanAction">
			<result name="success" type="json">
       	 		<param name="root">json</param>
       		</result>
      	</action>
      	<action name="getAgriDistrict" method="getAgriDistrict" class="agriLoanAction">
			<result name="success" type="json">
       	 		<param name="root">json</param>
       		</result>
      	</action>
      	<action name="subDistrictByDistrictId" method="getSubDistrictByDistrictId" class="agriLoanAction">
			<result name="success" type="json">
       	 		<param name="root">json</param>
       		</result>
      	</action>
      	<action name="villageBysubdistrictId" method="getVillageBysubdistrictId" class="agriLoanAction">
			<result name="success" type="json">
       	 		<param name="root">json</param>
       		</result>
      	</action>
      	
      	<action name="getAgriCityList" method="getAgriCity" class="agriLoanAction">
			<result name="success" type="json">
       	 		<param name="root">json</param>
       		</result>
      	</action>
