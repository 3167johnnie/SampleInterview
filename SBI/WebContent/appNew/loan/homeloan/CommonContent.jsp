<script type="text/javascript">
	function fetchJsonData(){
		jsonJSArray = '<s:property value="%{jsonJSArray1HomeLoan}"/>';
		jsonJSArray = jsonJSArray.replace(/%27/g, "\'");
		jsonJSArray = jsonJSArray.replace(/&quot;/g, "\"");
		jsonObject = jQuery.parseJSON(jsonJSArray);
		return jsonObject;
	}
	
	jQuery(document).ready(function(){
		apply_currency_form(document.homeloanform);
		$("#content-1").mCustomScrollbar({
			theme:"rounded",
			scrollInertia:5,
			callbacks:{
                onScroll:function(){ 
                    $("#date_of_birth, #co_date_of_birth1, #co_date_of_birth2").datepicker('place');
                 }
			},
			mouseWheel:{scrollAmount:30},
			scrollButtons:{
				enable:true
			},
			 advanced:{
				updateOnBrowserResize:true,
				updateOnContentResize:true,
				autoScrollOnFocus:true,
				autoExpanHorizontalScroll:true 
			}
			
		});
		$("body").on("focus","input:not(#date_of_birth, #co_date_of_birth1, #co_date_of_birth2),select",function(){
			 $("#content-1").mCustomScrollbar('scrollTo',$(this).prev());
		})
		
		dob_date_picker('homeloanform','date_of_birth');
		
		if($("#co_date_of_birth1")!=undefined){
			dob_date_picker('homeloanform','co_date_of_birth1');
		}
		if($("#co_date_of_birth2")!=undefined){
			dob_date_picker('homeloanform','co_date_of_birth2');
		} 
		
		<s:if test="%{quote.loanQuoteLoanCategoryId>=0}">
			change_value='<s:property value="%{quote.loanQuoteLoanCategoryId}"/>';
		</s:if>
	  	<s:if test="%{quote.loanQuoteLoanPurposeId>=0}">
	  		change_value_loanPurpose='<s:property value="%{quote.loanQuoteLoanPurposeId}"/>';
		</s:if>
		<s:if test="%{quote.loanQuoteLoanCategoryId==1 || quote.loanQuoteLoanCategoryId==2}">
			if(isRegisteredBuilder){
			}else{
				auto_suggestion('builderName');
			}
		</s:if>
		<s:if test="%{quote.loanQuoteEmploymentTypeId==1}">
			auto_suggestion_employer('employerName');
		</s:if>
		
		$("#appFirstName").keydown(function(event){
			return M.isChars(event);
		});
		apply_currency_form(document.homeloanform);
		<s:if test="%{isDsrPage=='false'}">
			<s:if test="%{#session.bankLMSUser==null}">
				<s:if test="%{appForm!=null && appForm.appMobileVerified!=null && appForm.appMobileVerified.equalsIgnoreCase('N')}">
					dropOffPopupStatus=1;
				</s:if>
			</s:if>
	  	</s:if>
	});
	
	preEMIs='<s:property value="%{quote.loanQuotePreEMIs}"/>';
        <%--	genderValue='<s:property value="%{quote.loanQuoteGender}"/>';--%>
        
	if(topUpStatus){
		jQuery("#loanPurpose option[value='1']").remove();
		jQuery("#loanPurpose option[value='2']").remove();
		jQuery("#loanPurpose option[value='3']").remove();
		jQuery("#loanPurpose option[value='4']").remove();
	}else{
   		jQuery("#loanPurpose option[value='5']").remove();
 	}
</script>
